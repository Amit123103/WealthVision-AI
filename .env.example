# Backend settings
SECRET_KEY=supersecretkey-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=postgresql://postgres:password@db:5432/wealth_platform

# Redis / Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# MinIO / S3
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=wealth-images
AWS_REGION=us-east-1

# AI Module
MODEL_WEIGHTS_PATH=./app/ai/dummy_weights.pt

# Geospatial Settings
OVERPASS_MIRRORS=https://overpass.kumi.systems/api/interpreter,https://lz4.overpass-api.de/api/interpreter,https://overpass.osm.ch/api/interpreter
MAP_RADIUS_OFFSET=0.012
